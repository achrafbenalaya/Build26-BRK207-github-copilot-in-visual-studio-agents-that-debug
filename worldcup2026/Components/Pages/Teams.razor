@page "/teams"
@using worldcup2026.Models
@using worldcup2026.Services
@inject WorldCupDataService DataService

<PageTitle>Teams — World Cup 2026</PageTitle>

<h2>🏳️ Teams</h2>

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Flag</th>
            <th>Team</th>
            <th>Group</th>
            <th>Attack</th>
            <th>Defense</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var team in DataService.GetTeams())
        {
            <tr>
                <td style="font-size:1.5rem">@team.Flag</td>
                <td>@team.Name</td>
                <td><span class="badge bg-secondary">Group @team.Group</span></td>
                <td>
                    <div class="progress" style="height:20px;width:120px">
                        <div class="progress-bar bg-danger" style="width:@(team.AttackRating * 10)%">
                            @team.AttackRating
                        </div>
                    </div>
                </td>
                <td>
                    <div class="progress" style="height:20px;width:120px">
                        <div class="progress-bar bg-primary" style="width:@(team.DefenseRating * 10)%">
                            @team.DefenseRating
                        </div>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
