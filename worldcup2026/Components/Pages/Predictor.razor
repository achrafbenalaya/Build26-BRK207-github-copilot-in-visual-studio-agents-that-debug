@page "/predictor"
@rendermode InteractiveServer
@using worldcup2026.Models
@using worldcup2026.Services
@inject WorldCupDataService DataService
@inject PredictionService PredictionSvc

<PageTitle>Predictor — World Cup 2026</PageTitle>

<h2>🔮 Match Predictor</h2>
<p class="text-muted">Select two teams and predict the winner.</p>

@{
    var teams = DataService.GetTeams();
    var home = teams.FirstOrDefault(t => t.Name == homeName);
    var away = teams.FirstOrDefault(t => t.Name == awayName);
}

<div class="row g-3 mt-2">
    <div class="col-md-5">
        <label class="form-label fw-bold">Home Team</label>
        <select class="form-select" @onchange="OnHomeChanged">
            @foreach (var t in teams)
            {
                <option value="@t.Name" selected="@(t.Name == homeName)">@t.Flag @t.Name</option>
            }
        </select>

        @if (home is not null)
        {
            <div class="card mt-3">
                <div class="card-body">
                    <h5 class="card-title">@home.Flag @home.Name</h5>
                    <div class="mb-2">
                        <span class="fw-bold">Attack: @home.AttackRating</span>
                        <div class="progress" style="height:18px">
                            <div class="progress-bar bg-danger" style="width:@(home.AttackRating * 10)%"></div>
                        </div>
                    </div>
                    <div class="mb-2">
                        <span class="fw-bold">Defense: @home.DefenseRating</span>
                        <div class="progress" style="height:18px">
                            <div class="progress-bar bg-primary" style="width:@(home.DefenseRating * 10)%"></div>
                        </div>
                    </div>
                    <div>
                        <span class="fw-bold">Strength: @(home.AttackRating - home.DefenseRating)</span>
                        <span class="text-muted">(ATK - DEF)</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-md-2 d-flex align-items-center justify-content-center">
        <span class="fs-3 fw-bold">VS</span>
    </div>

    <div class="col-md-5">
        <label class="form-label fw-bold">Away Team</label>
        <select class="form-select" @onchange="OnAwayChanged">
            @foreach (var t in teams)
            {
                <option value="@t.Name" selected="@(t.Name == awayName)">@t.Flag @t.Name</option>
            }
        </select>

        @if (away is not null)
        {
            <div class="card mt-3">
                <div class="card-body">
                    <h5 class="card-title">@away.Flag @away.Name</h5>
                    <div class="mb-2">
                        <span class="fw-bold">Attack: @away.AttackRating</span>
                        <div class="progress" style="height:18px">
                            <div class="progress-bar bg-danger" style="width:@(away.AttackRating * 10)%"></div>
                        </div>
                    </div>
                    <div class="mb-2">
                        <span class="fw-bold">Defense: @away.DefenseRating</span>
                        <div class="progress" style="height:18px">
                            <div class="progress-bar bg-primary" style="width:@(away.DefenseRating * 10)%"></div>
                        </div>
                    </div>
                    <div>
                        <span class="fw-bold">Strength: @(away.AttackRating - away.DefenseRating)</span>
                        <span class="text-muted">(ATK - DEF)</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    <button class="btn btn-success btn-lg" @onclick="Predict">Predict Winner</button>
</div>

@if (result is not null)
{
    <div class="alert alert-info mt-4 fs-5">
        🏆 @result
    </div>
}

@code {
    private string homeName = "";
    private string awayName = "";
    private string? result;

    protected override void OnInitialized()
    {
        var teams = DataService.GetTeams();
        homeName = teams[0].Name;
        awayName = teams[1].Name;
    }

    private void OnHomeChanged(ChangeEventArgs e) { homeName = e.Value?.ToString() ?? ""; result = null; }
    private void OnAwayChanged(ChangeEventArgs e) { awayName = e.Value?.ToString() ?? ""; result = null; }

    private void Predict()
    {
        var teams = DataService.GetTeams();
        var home = teams.First(t => t.Name == homeName);
        var away = teams.First(t => t.Name == awayName);
        result = PredictionSvc.Predict(home, away);
    }
}
