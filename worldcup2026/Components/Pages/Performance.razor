@page "/performance"
@rendermode InteractiveServer
@using System.Diagnostics
@using worldcup2026.Services
@inject SlowStandingsService SlowService

<PageTitle>Performance — World Cup 2026</PageTitle>

<h2>⚡ Performance</h2>
<p class="text-muted">Calculate group standings and measure execution time using <code>Stopwatch</code>.</p>

<button class="btn btn-primary btn-lg mt-2" @onclick="RunTest" disabled="@running">
    @(running ? "Running…" : "▶ Run Test")
</button>

@if (slowMs >= 0)
{
    <div class="mt-4">
        <table class="table table-bordered w-auto">
            <thead class="table-dark">
                <tr><th>Method</th><th>Time (ms)</th></tr>
            </thead>
            <tbody>
                <tr class="table-danger">
                    <td>SlowStandingsService</td>
                    <td>@slowMs ms</td>
                </tr>
            </tbody>
        </table>
        <p class="mt-2 text-muted">
            🤔 That seems slow… Try using the <strong>Visual Studio Profiler</strong> to find out why!
        </p>
    </div>
}

@code {
    private long slowMs = -1;
    private bool running = false;

    private async Task RunTest()
    {
        running = true;
        StateHasChanged();
        await Task.Delay(10);

        var sw = Stopwatch.StartNew();
        SlowService.GetStandings();
        sw.Stop();
        slowMs = sw.ElapsedMilliseconds;

        running = false;
    }
}
